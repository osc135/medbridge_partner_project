{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -e . && cd frontend && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "uvicorn ai_health_coach.api.routes:app --host 0.0.0.0 --port ${PORT:-8000}",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
